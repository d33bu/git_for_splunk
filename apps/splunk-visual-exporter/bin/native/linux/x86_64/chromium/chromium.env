APPDIR=$ORIGIN
APPIMAGE_UUID=NL0JmmP
APPDIR_EXEC_PATH=$APPDIR/usr/lib/chromium/headless_shell
APPDIR_EXEC_ARGS=$@
XDG_DATA_DIRS=$APPDIR/usr/share
XDG_CONFIG_DIRS=$APPDIR/etc/xdg
APPDIR_LIBRARY_PATH=$APPDIR/lib/x86_64-linux-gnu:$APPDIR/usr/lib/chromium:$APPDIR/usr/lib/x86_64-linux-gnu:$APPDIR/lib/x86_64
PATH=$APPDIR/usr/lib/chromium:$APPDIR/usr/lib/x86_64-linux-gnu/glib-2.0:$APPDIR/usr/share/bug/libgbm1:$APPDIR/usr/share/libgcrypt20:$PATH
GIO_MODULE_DIR=$APPDIR/usr/lib/x86_64-linux-gnu/gio/modules
GSETTINGS_SCHEMA_DIR=$APPDIR/usr/share/glib-2.0/schemas
GTK_EXE_PREFIX=$APPDIR/usr
GTK_DATA_PREFIX=$APPDIR/usr
APPDIR_LIBC_LINKER_PATH=lib64/ld-linux-x86-64.so.2
APPDIR_LIBC_LIBRARY_PATH=$APPDIR/runtime/compat/usr/lib/x86_64-linux-gnu/gconv:$APPDIR/runtime/compat/lib/x86_64-linux-gnu:$APPDIR/runtime/compat/lib64
APPDIR_LIBC_VERSION=9999999.9999
HOME=$APPDIR/usr/share
FONTCONFIG_SYSROOT=$APPDIR
XDG_DATA_HOME=$APPDIR
APPDIR_PATH_MAPPINGS=/builds/devplat/chromium-locked-down/AppDir:$APPDIR;
