msgid "<span class=\"info-message alert alert-info\"><i class=\"icon-alert\"/>You have selected \"host\" or \"source\" from the \"Split By\" menu. You might see usage reported for a \"SQUASHED\" series. This is expected behavior if you have many unique hosts or sources. <a href=\"/help?location=learnmore.license.usage_squashing\" target=\"_blank\" title=\"Splunk help\">Learn More <i class=\"icon-external\"/></a></span>"
msgstr "<span class=\"info-message alert alert-info\"><i class=\"icon-alert\"/>Sie haben \"host\" oder \"source\" aus dem Menü \"Teilen bei\" ausgewählt. Eventuell wird die Nutzung für eine \"KOMPRIMIERT\"-Reihe gemeldet. Dies ist das erwartete Verhalten, wenn Sie über viele eindeutige Hosts oder Quellen verfügen. <a href=\"/help?location=learnmore.license.usage_squashing\" target=\"_blank\" title=\"Splunk help\">Erfahren Sie mehr <i class=\"icon-external\"/></a></span>"

#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/license_usage_historic.xml:157
msgid "<span class=\"info-message alert alert-info\"><i class=\"icon-alert\"/>You have selected \"index\" from the \"Split By\" menu. If your license peers are running a version of Splunk lower than 6.0, they will not report per index usage and you will see their usage labeled as \"UNKNOWN\".</span>"
msgstr "<span class=\"info-message alert alert-info\"><i class=\"icon-alert\"/>Sie haben \"index\" aus dem Menü \"Teilen bei\" ausgewählt. Wenn Ihre Lizenz-Peers eine Splunk-Version vor 6.0 ausführen, melden sie die Nutzung pro Index nicht und ihre Nutzung wird als \"UNBEKANNT\" angegeben.</span>"

#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/license_usage_historic.xml:150
msgid "<span class=\"info-message alert alert-warning\"><i class=\"icon-alert\"/> The report that powers these panels is not accelerated.  For faster performance, turn on acceleration for this report. <a href=\"/help?location=learnmore.DMC.LURV.acceleration\" target=\"_blank\" title=\"Splunk help\">Learn more <i class=\"icon-external\"/></a></span><br/><br/>"
