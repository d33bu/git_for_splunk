#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/distributed_search_deployment.xml:213 /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/distributed_search_deployment.xml:291 /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/distributed_search_instance.xml:388
msgid "<p><b>Authentication:</b> the search head requests an authentication token from the peer's /services/admin/auth-tokens endpoint. </p><p><b>Get Bundle List:</b> the search head requests a list of available knowledge bundles from the peer's /services/admin/bundles endpoint. </p><p><b>Get Peer Info:</b> the search head requests instance information from the peer's /services/server/info endpoint. </p>"
msgstr "<p><b>認証：</b>サーチヘッドはピアの/services/admin/auth-tokensエンドポイントから認証トークンを要求します。</p><p><b>バンドルリストの取得：</b>サーチヘッドはピアの/services/admin/bundlesエンドポイントから使用可能なナレッジバンドルのリストを要求します。</p><p><b>ピア情報の取得：</b>サーチヘッドはピアの/services/server/infoエンドポイントからインスタンス情報を要求します。</p>"

#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/scheduler_activity_instance.env_cloud.xml:557 /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/scheduler_activity_instance.xml:681
msgid "<p><b>Execution Latency</b> = Dispatch Time - (Scheduled Time + Schedule Window Time)</p><p>The execution latency expresses the delay in seconds between the planned dispatch time of a search and its actual dispatch time. It takes into account a schedule window if one is configured for this search. <a href=\"/help?location=learnmore.report.scheduled\" target=\"_blank\" class=\"external\">Learn More</a></p>"
msgstr "<p><b>実行待ち時間</b> =ディスパッチ時間- (スケジュール時間+スケジュールウィンドウ時間)</p><p>実行待ち時間は、予定されているサーチのディスパッチ時間と実際のディスパッチ時間における遅延を秒単位で示します。<a href=\"/help?location=learnmore.report.scheduled\" target=\"_blank\" class=\"external\">詳細</a></p>"

#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/scheduler_activity_instance.env_cloud.xml:496 /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/scheduler_activity_instance.prod_lite.xml:106 /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/scheduler_activity_instance.xml:619
msgid "<p><b>Interval Load Factor</b> = Average Runtime / Schedule Interval * 100</p>"
msgstr "<p><b>内部ロード要素</b> =平均ランタイム/スケジュール間隔* 100</p>"

#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/forwarder_instance.env_cloud.xml:49
msgid "<p><b>Note: </b>Multiple forwarders installed on one host appear with identical host names, but different GUIDs.</p>"
msgstr "<p><b>注意：</b>複数のフォワーダーがホストにインストールされている場合、ホスト名の表示でGUIDが異なります。</p>"

#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/forwarder_deployment.xml:288
msgid "<p><b>Note:</b> \"Forwarder connection count\" is the total number of connections between forwarders and receivers. For example, if a forwarder connects to three receivers, its count is three.</p>"
msgstr "<p><b>注意：</b>「Forwarder connection count」はフォワーダーと受け取り側で通信を行った回数です。たとえば、フォワーダーが3ヶ所の受取側と接続した場合、カウントは3となります。</p>"

#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/forwarder_deployment.xml:224
msgid "<p><b>Note:</b> \"Forwarder\" is the GUID. \"Receiver\" is \"serverName:port\" combination.</p>"
msgstr "<p><b>注意：</b>「Forwarder」はGUIDです。「Receiver」は「serverName:port」と組み合わされています。</p>"

#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/forwarder_deployment.env_cloud.xml:51 /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/forwarder_deployment.xml:62 /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/forwarder_overview.prod_lite.xml:31
msgid "<p><b>Note:</b> A forwarder is \"missing\" if it does not connect to indexers for 15 minutes. Forwarder status takes 30 minutes minimum to reflect a monitoring data collection interval of 15 minutes, and higher intervals can take longer.</p>"
msgstr "<p><b>注意:</b> フォワーダーが15分間インデクサーに接続しないと、そのフォワーダーは「欠落」したものと見なされます。監視データ収集間隔が15分である場合、フォワーダーのステータスに反映されるまで30分を要し、間隔が長くなればさらに長い時間がかかります。</p>"

#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/scheduler_activity_instance.env_cloud.xml:196 /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/scheduler_activity_instance.xml:240
msgid "<p><b>Skip Ratio and Execution Latency</b>: The single values show data in the past full hour. Trends compare to 1 hour before that. Sparklines show data over past 24 hours.</p>"
msgstr "<p><b>スキップレシオと実行待ち時間</b>：単一の値は過去1時間のデータを表示します。トレンドは1時間前と比較します。スパークラインは過去24時間のデータを表示します。</p>"

#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/volume_detail_deployment.xml:119
msgid ""
"<p><b>Volume Usage:</b>\n"
"          The first value is the current size of the volume. The second value is the volume capacity, as specified by the maxVolumeDataSizeMB attribute in\n"
"          <a href=\"/help?location=learnmore.index.settings\" class=\"external\" target=\"_blank\">indexes.conf</a>.\n"
"        </p><p><b>Note:</b>\n"
"          if the volume is \"unlimited\", it is not possible to determine the disk usage for the volume.\n"
"        </p>"
msgstr "<p><b>ボリューム使用法：</b>最初の値は、ボリュームの現在のサイズです。第2の値は、<a href=\"/help?location=learnmore.index.settings\" class=\"external\" target=\"_blank\">indexes.conf</a>.</p><p><b>NoteでmaxVolumeDataSizeMB属性で指定された通り、ボリュームの容量です</b>：ボリュームが「unlimited」である場合、ボリュームのディスク使用量を決定することは不可能です。</p>"

#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/indexes_and_volumes_instance.xml:183 /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/volume_detail_instance.xml:194
msgid "<p><b>Volume Usage:</b> The first value is the current size of the volume. The second value is the volume capacity, as specified by the maxVolumeDataSizeMB attribute in <a href=\"/help?location=learnmore.index.settings\" class=\"external\" target=\"_blank\">indexes.conf</a>.</p><p><b>Note: </b>if the volume is \"unlimited\", it is not possible to determine the disk usage for the volume. </p>"
msgstr "<p><b>ボリューム使用法：</b>最初の値は、ボリュームの現在のサイズです。第2の値は、<a href=\"/help?location=learnmore.index.settings\" class=\"external\" target=\"_blank\">indexes.conf</a>.</p><p><b>NoteでmaxVolumeDataSizeMB属性で指定された通り、ボリュームの容量です</b>：ボリュームが「unlimited」である場合、ボリュームのディスク使用量を決定することは不可能です。</p>"

#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/shc_scheduler_delegation_statistics.xml:258
msgid "<p><b>delegated_waiting</b>: The number of jobs currently running on members.</p><p><b>delegated_scheduled</b>: The number of jobs that the captain is trying to contact members to start running. This is usually 0, unless the captain or network is backed up.</p><p><b>max_pending</b>: The number of jobs pending over a 30 second period.</p>"
msgstr "<p><b>delegated_waiting</b>：現在メンバーに実行中のジョブの数。</p><p><b> delegated_scheduled </b>：キャプテンが、実行開始にするように連絡を取ろうとしているジョブの数。キャプテンのネットワークがバックアップされている限り、通常は0です。</p><p><b> max_pending </b>：30秒にわたって保留中のジョブ数。</p>"

#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/shc_scheduler_delegation_statistics.xml:208
msgid "<p><b>dispatched</b>: The number of scheduled search jobs that the captain successfully dispatched to members.</p><p><b>skipped</b>: The number of jobs that were skipped and not dispatched.</p><p><b>delegated</b>: The number of jobs that the captain attempted to dispatch. This is usually the same as the number of dispatched jobs.</p>"
msgstr "<p><b>発信済み</b>：キャプテンがmembers.skippedに上手く発信したスケジュールサーチジョブの数。</p><p><b>スキップ済み</b>：スキップされ発信されなかったジョブの数。</p><p><b>委任済み</b>：キャプテンが発信しようとしたジョブの数。通常、発信したジョブと同じ数となります。</p>"

#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/volume_detail_instance.xml:262
msgid "<p><center>Volume Usage (GB)</center></p>"
msgstr "<p><center>ボリュームの使用(GB) </center></p>"

