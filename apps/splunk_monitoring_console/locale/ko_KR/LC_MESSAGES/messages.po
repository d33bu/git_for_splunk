#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/resource_usage_deployment.xml:211 /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/resource_usage_deployment.xml:262
