#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/data_quality.env_cloud.xml:3
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/data_quality.xml:3
msgid ""
"\n"
"      This dashboard helps you assess the quality of your incoming data by revealing issues that\n"
"      occur when the data is being indexed. These issues appear as warnings and errors in your splunkd.log.\n"
"  "
msgstr ""
"\n"
"      Questa dashboard aiuta a valutare la qualità dei dati in ingresso evidenziando i problemi\n"
"      che si verificano al momento dell'indicizzazione dei dati. Questi problemi sono presentati come avvisi o errori nel log splunkd.log.\n"
"  "

#. description
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/resource_usage_cpu_instance.xml:3
msgid ""
"\n"
"    This dashboard consolidates panels from other Monitoring Console dashboards to help you assess the CPU usage of a Splunk instance.\n"
"  "
msgstr ""
"\n"
"    Questa dashboard raggruppa i pannelli da altre dashboard della Console di monitoraggio per aiutarti a valutare l'utilizzo della CPU di un'istanza Splunk.\n"
"  "

#. description
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/resource_usage_cpu_deployment.xml:3
msgid ""
"\n"
"    This dashboard consolidates panels from other Monitoring Console dashboards to help you assess the CPU usage of your Splunk deployment.\n"
"  "
msgstr ""
"\n"
"    Questa dashboard raggruppa i pannelli da altre dashboard della Console di monitoraggio per aiutarti a valutare l'utilizzo della CPU del tuo deployment Splunk.\n"
"  "

