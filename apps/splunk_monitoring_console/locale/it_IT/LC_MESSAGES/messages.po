#. html
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/index_detail_deployment.xml:68
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/index_detail_instance.xml:125
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/indexes_and_volumes_deployment.xml:23
#: /Users/alalji/Downloads/splunk/etc/apps/splunk-monitoring-console/default/data/ui/views/indexes_and_volumes_instance.xml:38
